<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_hris_employee" model="res.groups">
            <field name="name">HRIS Employee</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_hris_hr_admin" model="res.groups">
            <field name="name">HRIS HR Admin</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('hris_core.group_hris_employee'))]"/>
        </record>
    </data>

    <data>
        <record id="rule_hr_employee_own_data" model="ir.rule">
            <field name="name">HRIS Employee: own hr.employee</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[('id', '=', user.employee_id.id)]</field>
            <field name="groups" eval="[(4, ref('hris_core.group_hris_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_admin_all_data" model="ir.rule">
            <field name="name">HRIS HR Admin: all hr.employee</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hris_core.group_hris_hr_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>

