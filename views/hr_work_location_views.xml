<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_work_location_form_inherit_hris_employee" model="ir.ui.view">
            <field name="name">hr.work.location.form.hris.employee</field>
            <field name="model">hr.work.location</field>
            <field name="inherit_id" ref="hr.hr_work_location_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group>
                        <field name="location_status"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

